# PaPaPhone — конфигурация
# Скопируйте в data/.env и отредактируйте.
# Строки с # — комментарии. Переменные окружения (export) имеют приоритет.

# --- Модель распознавания речи ---
# vosk-model-small-ru-0.22 (45 MB, быстрая) или vosk-model-ru-0.42 (1.8 GB, точнее)
PAPAPHONE_VOSK_MODEL=vosk-model-small-ru-0.22

# --- Звонки: "voip" (SIP) или "modem" (AT через SIM7600) ---
PAPAPHONE_CALL_MODE=voip

# --- SIP (для CALL_MODE=voip) ---
PAPAPHONE_SIP_SERVER=sip.zadarma.com
PAPAPHONE_SIP_USER=
PAPAPHONE_SIP_PASSWORD=
PAPAPHONE_SIP_PORT=5060

# --- Модем (SMS + интернет, опционально звонки если CALL_MODE=modem) ---
PAPAPHONE_MODEM_PORT=/dev/ttyUSB0

# --- Wake-фразы (через запятую) ---
PAPAPHONE_WAKE_PHRASES=телефон,папафон

# --- Адрес проживания (озвучивается по команде «адрес» и в SMS при экстренном вызове) ---
PAPAPHONE_HOME_ADDRESS=Москва, ул. Примерная, д. 1, кв. 5

# --- Экстренные ---
# Номер 112 (Скорая) создаётся в БД автоматически при первом запуске.
# Экстренные контакты (кому SMS при вызове 112) настраиваются через секретное меню.

# --- Ночной режим (SMS копятся, утром уведомление) ---
PAPAPHONE_NIGHT_START=23
PAPAPHONE_NIGHT_END=9

# --- Аудио (оставьте пустым для автовыбора) ---
# PAPAPHONE_AUDIO_INPUT_DEVICE=1
# PAPAPHONE_AUDIO_OUTPUT_DEVICE=0
